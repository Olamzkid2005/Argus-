#!/usr/bin/env node
/**
 * Argus Security CLI — V5
 *
 * Delegates to the TypeScript source via bun.
 * Usage: argus <command> [options]
 *        argus doctor
 *        argus assess https://example.com
 *        argus --help
 */
import { spawn } from "child_process"
import { fileURLToPath } from "url"
import { dirname, join } from "path"

const __dirname = dirname(fileURLToPath(import.meta.url))
const entry = join(__dirname, "..", "src", "argus", "index.ts")

const child = spawn("bun", ["run", entry, ...process.argv.slice(2)], {
  stdio: "inherit",
})

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal)
    return
  }
  process.exit(typeof code === "number" ? code : 0)
})
