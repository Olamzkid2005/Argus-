# ═══════════════════════════════════════════════════════════════
# NOTE: The root .env.example uses LLM_API_KEY (read by TUI).
# The separate OPENAI_API_KEY / ANTHROPIC_API_KEY vars below
# are for internal worker use only and are NOT read by the TUI.
# ═══════════════════════════════════════════════════════════════

# Database Configuration
# ⚠ These values must match what's in your root .env (or docker-compose.yml).
# Change the password before using in production.
POSTGRES_USER=argus_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=argus_pentest
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# NOTE: URL uses plain values (not ${VAR} references) because .env files
# don't support shell variable expansion. The values above are for reference.
DATABASE_URL=postgresql://argus_user:change_me_in_production@localhost:5432/argus_pentest

# ── Database Connection Pool ────────────────────────────────────
# Fine-tune pool sizing for your workload.
# DB_POOL_MIN=2
# DB_POOL_MAX=20
# DB_SLOW_QUERY_MS=500          # Log queries slower than this threshold (ms)
# DB_STATEMENT_TIMEOUT_MS=30000 # Max query execution time (ms)

# ── Database SSL / PgBouncer ────────────────────────────────────
# USE_PGBOUNCER=false
# PGBOUNCER_MODE=transaction
# SSL_MODE=require

# Redis Configuration
# When running workers locally (standalone, outside Docker):
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# When running via docker-compose, use the compose service name:
# REDIS_URL=redis://redis:6379

# Optional: Redis password for secured deployments.
# REDIS_PASSWORD=

# ── Redis Cache ────────────────────────────────────────────────
# Separate Redis database for caching (defaults to DB 2).
# CACHE_REDIS_DB=2
# CACHE_REDIS_URL=redis://localhost:6379/2  # Override full URL

# AI API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Auth Checkpoint Encryption (required for register/login tools) ──
# Fernet key for encrypting auth session tokens at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, auth checkpoint operations will raise a RuntimeError at startup.
# AUTH_CHECKPOINT_KEY=

# ── Settings Encryption ────────────────────────────────────────
# Key for encrypting user settings in the database.
# If not set, a random key is generated at worker startup (in-memory only;
# settings stored before a restart will be unreadable afterwards).
# SETTINGS_ENCRYPTION_KEY=

# Worker Configuration
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=INFO
# Grace period for in-flight tasks during worker shutdown (seconds).
# WORKER_SHUTDOWN_TIMEOUT=120

# ── JWT Authentication ─────────────────────────────────────────
# Used for token-based auth between services. Minimum 32 characters.
# Generate with: openssl rand -base64 32
# JWT_SECRET=

# Tool Paths (will be configured when tools are installed)
NUCLEI_PATH=/usr/local/bin/nuclei
HTTPX_PATH=/usr/local/bin/httpx
SUBFINDER_PATH=/usr/local/bin/subfinder
FFUF_PATH=/usr/local/bin/ffuf
SQLMAP_PATH=/usr/local/bin/sqlmap

# ── Tool Runner ─────────────────────────────────────────────────
# Extra PATH entries for tool discovery, and tool enforcement mode.
# ARGUS_EXTRA_PATH=/opt/custom-tools/bin
# ARGUS_ENFORCE_TOOLS=1           # Fail if required tools not found

# ── Wordlists & Nuclei Templates ────────────────────────────────
# Override default paths. Defaults to ../wordlists/ and ../tool_assets/nuclei-templates/
# ARGUS_WORDLIST_DIR=
# ARGUS_NUCLEI_TEMPLATES=

# ── LLM Provider (detailed) ─────────────────────────────────────
# Override auto-detected provider and API URL.
# LLM_PROVIDER=openai
# LLM_API_URL=https://api.openai.com/v1/chat/completions

# ── LLM Client Settings ─────────────────────────────────────────
# LLM_MODEL=gemini-2.0-flash       # Default model
# LLM_API_KEY=                      # Falls back to OPENAI_API_KEY

# ── LLM Agent (ReAct Loop) Configuration ──────────────────────────
# Model for LLM-driven tool selection and report generation
# LLM_AGENT_MODEL=gpt-4o-mini
# Maximum cost per engagement for LLM calls (USD)
# LLM_AGENT_MAX_COST_USD=0.25
# Maximum iterations in the agent loop
# LLM_AGENT_MAX_ITERATIONS=10
# Per-iteration timeout in seconds
# LLM_AGENT_TIMEOUT_SECONDS=30
# LLM_AGENT_TEMPERATURE=0.1           # Sampling temperature (0.0-1.0)
# LLM_AGENT_ZERO_FINDING_STOP=4       # Stop after N consecutive zero-finding iterations
# LLM_AGENT_COST_PER_1K_INPUT=0.000150
# LLM_AGENT_COST_PER_1K_OUTPUT=0.000600

# ── Rate Limiting ──────────────────────────────────────────────
# Controls concurrency and delay for LLM and web requests.
# ARGUS_RATE_LIMIT_DELAY_MS=200
# ARGUS_MAX_CONCURRENT=20

# ── Web Scanner ────────────────────────────────────────────────
# ARGUS_WEB_SCANNER_CHECK_TIMEOUT=600   # Max time for all checks (seconds)
# ARGUS_SCOPE_VALIDATION_TIMEOUT=5      # Scope DB lookup timeout
# WEB_SCANNER_USER_AGENT=               # Custom User-Agent header

# ── Metrics & Health Server ─────────────────────────────────────
# Internal HTTP server for Prometheus metrics and health checks.
# ARGUS_METRICS_HOST=127.0.0.1
# ARGUS_METRICS_PORT=9090
# ARGUS_METRICS_VERBOSE=0        # Set to 1 for verbose metrics logging

# ── Error Alerts ────────────────────────────────────────────────
# Webhook URL for sending HIGH/CRITICAL error alerts.
# If unset, alerts are logged to stderr only.
# ALERT_WEBHOOK_URL=https://hooks.example.com/argus-alerts

# ── Webhook IP Allowlist (SSRF prevention) ─────────────────────
# Restrict webhook dispatch to specific CIDR ranges.
# Comma-separated CIDR notation (e.g. "192.30.252.0/22,140.82.112.0/20")
# ARGUS_WEBHOOK_ALLOWED_IPS=

# ── License Policy Scanning ─────────────────────────────────────
# License compliance policies for repo scanning.
# Comma-separated SPDX identifiers.
# ARGUS_LICENSE_POLICY_BLOCKED=AGPL-3.0,BSL-1.1
# ARGUS_LICENSE_POLICY_WARN=LGPL-3.0,GPL-3.0
# ARGUS_LICENSE_POLICY_ALLOWED=MIT,Apache-2.0,BSD-3-Clause

# ── Feature Flags ───────────────────────────────────────────────
# Rollout timestamp for feature-flagged changes (ISO 8601).
# Engagements created before this use the old code path.
# ARGUS_FF_ROLLOUT_TIMESTAMP=

# ── Git SSRF Prevention ────────────────────────────────────────
# Additional git hosts to allow (comma-separated).
# ARGUS_ALLOWED_GIT_HOSTS=git.example.com,git.internal.dev

# ── OpenTelemetry ──────────────────────────────────────────────
# Export spans to an OTLP-compatible collector.
# When unset, spans are logged to console only.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── SSL/TLS ────────────────────────────────────────────────────
# SSL_CERT_PATH=/etc/ssl/certs/argus.crt
# TLS_ENABLED=true

# ── Upstash Redis (REST-based rate limiting) ───────────────────
# UPSTASH_REDIS_REST_URL=https://us1-xxxxx.upstash.io

# ── MCP Transport ──────────────────────────────────────────────
# Heartbeat timeout for the MCP stdio transport (0 = disabled).
# ARGUS_MCP_HEARTBEAT_TIMEOUT_SECS=60

# ── Findings ────────────────────────────────────────────────────
# Maximum findings per engagement before pruning.
# MAX_FINDINGS_PER_ENGAGEMENT=50000

# ── Vault (optional secrets backend) ────────────────────────────
# VAULT_ADDR=https://vault:8200
# VAULT_TOKEN=hvs.xxxxx
# VAULT_SKIP_VERIFY=false
# VAULT_TIMEOUT=10,30
# VAULT_SECRET_PATH=secret/argus

# ── AWS (optional secrets backend) ──────────────────────────────
# AWS_REGION=us-east-1
# AWS_TIMEOUT=10

# ── Go Binary Path ──────────────────────────────────────────────
# GO_BIN_PATH=~/go/bin

# ── Autonomous Mode ────────────────────────────────────────────
# ARGUS_AUTONOMOUS=1
# ARGUS_AUTO_APPROVE=1
# ARGUS_AUTO_ANSWER=auto
