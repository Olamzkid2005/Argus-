# Database Configuration
DATABASE_URL=postgresql://argus_user:argus_dev_password_change_in_production@localhost:5432/argus_pentest

# Redis Configuration
REDIS_URL=redis://localhost:6379
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Worker Configuration
WORKER_CONCURRENCY=4
WORKER_LOG_LEVEL=INFO

# Tool Paths (will be configured when tools are installed)
NUCLEI_PATH=/usr/local/bin/nuclei
HTTPX_PATH=/usr/local/bin/httpx
SUBFINDER_PATH=/usr/local/bin/subfinder
FFUF_PATH=/usr/local/bin/ffuf
SQLMAP_PATH=/usr/local/bin/sqlmap

# ── LLM Agent (ReAct Loop) Configuration ──────────────────────────
# Model for LLM-driven tool selection and report generation
# LLM_AGENT_MODEL=gpt-4o-mini
# Maximum cost per engagement for LLM calls (USD)
# LLM_AGENT_MAX_COST_USD=0.25
# Maximum iterations in the agent loop
# LLM_AGENT_MAX_ITERATIONS=10
# Per-iteration timeout in seconds
# LLM_AGENT_TIMEOUT_SECONDS=30
