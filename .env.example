# ═══════════════════════════════════════════════════════════════
# Argus Platform — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# Then edit .env (DO NOT commit .env to git).
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────────
# Generate a strong password with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_USER=argus_user
POSTGRES_DB=argus_pentest
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Database URL (required — all services use this to connect) ──
# IMPORTANT: Change the password BOTH here AND in POSTGRES_PASSWORD above.
# They MUST match. If they diverge, PostgreSQL authentication will fail
# and the error message is cryptic.
DATABASE_URL=postgresql://argus_user:change_me_in_production@postgres:5432/argus_pentest

# ── Database Connection Pool ────────────────────────────────────
# Connection pool sizing for PostgreSQL. Tune based on workload.
# DB_POOL_MIN=2
# DB_POOL_MAX=20
# DB_SLOW_QUERY_MS=500        # Log queries slower than this threshold (ms)
# DB_STATEMENT_TIMEOUT_MS=30000  # Max query execution time (ms)

# ── Database SSL / PgBouncer ────────────────────────────────────
# When using PgBouncer in transaction mode, set USE_PGBOUNCER=true.
# SSL_MODE controls the sslmode parameter in the connection string.
# USE_PGBOUNCER=false
# PGBOUNCER_MODE=transaction
# SSL_MODE=require

# ── Redis ──────────────────────────────────────────────────────
# When running via docker-compose, use the compose service name:
REDIS_URL=redis://redis:6379
# When running workers locally (outside Docker), use localhost:
# REDIS_URL=redis://localhost:6379

# Redis password for secured deployments. When set, all Redis
# connections authenticate with this password.
# REDIS_PASSWORD=

# ── Redis Cache ────────────────────────────────────────────────
# Separate Redis database for caching (defaults to DB 2).
# CACHE_REDIS_DB=2
# CACHE_REDIS_URL=redis://redis:6379/2   # Override full URL (defaults to REDIS_URL/2)

# ── NextAuth ───────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 32
# If empty, auth will fail at startup.
# CHANGE THIS BEFORE DEPLOYMENT — do not use the placeholder in production.
NEXTAUTH_SECRET=change_me_in_production_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# ── JWT Authentication ─────────────────────────────────────────
# Used for token-based auth between services.
# Generate with: openssl rand -base64 32 (minimum 32 characters).
# JWT_SECRET=

# ── Celery ─────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── LLM / AI Provider ──────────────────────────────────────────
# Supported providers:
#   Google Gemini (free): Get key at https://aistudio.google.com → Get API Key
#   OpenRouter: Get key at https://openrouter.ai/keys
#   OpenAI: Get key at https://platform.openai.com/api-keys
#   Anthropic: Set LLM_PROVIDER=anthropic AND LLM_API_URL explicitly
#
# Set your key here. The LLM client auto-detects the provider from the key prefix:
#   AIzaSy... or AQ.... → Gemini (uses Google's OpenAI-compatible endpoint)
#   sk-or-...          → OpenRouter
#   sk-...             → OpenAI
#   sk-ant-...         → Anthropic (requires LLM_PROVIDER=anthropic to be set)
#   anything else      → Generic (set LLM_API_URL if needed)
LLM_API_KEY=
LLM_MODEL=gemini-2.0-flash

# Optional: Override the auto-detected provider and API URL.
# Use when the auto-detected settings don't match your setup.
# LLM_PROVIDER=openai
# LLM_API_URL=https://api.openai.com/v1/chat/completions

# Optional: Separate key for Anthropic (used by workers only).
# ANTHROPIC_API_KEY=

# ── Auth Checkpoint Encryption ─────────────────────────────────
# REQUIRED when using the auth checkpoint feature (register/login tools).
# Fernet key for encrypting session tokens at rest.
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# AUTH_CHECKPOINT_KEY=

# ── Settings Encryption ────────────────────────────────────────
# Optional: Key for encrypting user settings in the database.
# If not set, a random key is generated at worker startup (in-memory only;
# settings will be unreadable after restart).
# SETTINGS_ENCRYPTION_KEY=

# ── LLM Agent Settings (overrides for the ReAct agent loop) ─────
# When LLM_AGENT_MODEL is set, it overrides LLM_MODEL for agent decisions.
# Defaults to gpt-4o-mini if not set.
# LLM_AGENT_MODEL=gpt-4o-mini
# LLM_AGENT_MAX_ITERATIONS=10
# LLM_AGENT_ZERO_FINDING_STOP=4
# LLM_AGENT_TEMPERATURE=0.1          # Sampling temperature (0.0-1.0)
# LLM_AGENT_TIMEOUT_SECONDS=30       # Per-iteration timeout
# LLM_AGENT_MAX_COST_USD=0.25        # Max cost per engagement
# LLM_AGENT_COST_PER_1K_INPUT=0.000150
# LLM_AGENT_COST_PER_1K_OUTPUT=0.000600

# ── Rate Limiting ──────────────────────────────────────────────
# Controls concurrency and delay for LLM and web requests.
# ARGUS_RATE_LIMIT_DELAY_MS=200
# ARGUS_MAX_CONCURRENT=20

# ── Web Scanner ────────────────────────────────────────────────
# Timeouts and scanners for the web scanning subsystem.
# ARGUS_WEB_SCANNER_CHECK_TIMEOUT=600   # Max time for all checks (seconds)
# ARGUS_SCOPE_VALIDATION_TIMEOUT=5      # Scope DB lookup timeout
# WEB_SCANNER_USER_AGENT=               # Custom User-Agent for requests

# ── Tools / Wordlists ──────────────────────────────────────────
# Override default paths for wordlists and nuclei templates.
# ARGUS_WORDLIST_DIR=                   # Default: ../wordlists/ relative to workers
# ARGUS_NUCLEI_TEMPLATES=               # Default: ../tool_assets/nuclei-templates/

# ── Git SSRF Prevention ────────────────────────────────────────
# Additional git hosts to allow (comma-separated).
# By default, only well-known public git hosts are allowed.
# ARGUS_ALLOWED_GIT_HOSTS=git.example.com,git.internal.dev

# ── Autonomous Mode Settings ────────────────────────────────────
# When set to 1, enables autonomous mode with auto-approval for
# destructive gates and hard failure on config errors.
# ARGUS_AUTONOMOUS=1
# ARGUS_AUTO_APPROVE=1
# ARGUS_AUTO_ANSWER=auto  # Default answer when LLM asks questions

# ── Metrics & Health Server ─────────────────────────────────────
# Internal HTTP server for Prometheus metrics and health checks.
# ARGUS_METRICS_HOST=127.0.0.1
# ARGUS_METRICS_PORT=9090
# ARGUS_METRICS_VERBOSE=0        # Set to 1 for verbose metrics logging

# ── Error Alerts ────────────────────────────────────────────────
# Webhook URL for sending HIGH/CRITICAL error alerts.
# The webhook receives a JSON payload with severity, message, and timestamp.
# If unset, alerts are logged to stderr only.
# ALERT_WEBHOOK_URL=https://hooks.example.com/argus-alerts

# ── License Policy Scanning ─────────────────────────────────────
# License compliance policies for repo scanning.
# Comma-separated lists of SPDX license identifiers.
# ARGUS_LICENSE_POLICY_BLOCKED=AGPL-3.0,BSL-1.1
# ARGUS_LICENSE_POLICY_WARN=LGPL-3.0,GPL-3.0
# ARGUS_LICENSE_POLICY_ALLOWED=MIT,Apache-2.0,BSD-3-Clause

# ── Feature Flags ───────────────────────────────────────────────
# Timestamp for rolling out feature-flagged changes to in-flight engagements.
# Format: ISO 8601 (e.g. "2026-06-01T00:00:00+00:00")
# Engagements created before this timestamp keep using the old code path.
# ARGUS_FF_ROLLOUT_TIMESTAMP=

# ── OpenTelemetry ──────────────────────────────────────────────
# Optional: Export spans to an OTLP-compatible collector.
# When unset, spans are logged to console only.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ── SSL/TLS (for production deployments) ────────────────────────
# Path to SSL certificate and key for TLS-enabled endpoints.
# SSL_CERT_PATH=/etc/ssl/certs/argus.crt
# TLS_ENABLED=true

# ── Upstash Redis (rate limiting via REST API) ──────────────────
# Optional: REST-based rate limiting for API endpoints.
# UPSTASH_REDIS_REST_URL=https://us1-xxxxx.upstash.io

# ── Webhook IP Allowlist ────────────────────────────────────────
# SSRF prevention: restrict webhook dispatch to specific CIDR ranges.
# Comma-separated CIDR notation (e.g. "192.30.252.0/22,140.82.112.0/20")
# ARGUS_WEBHOOK_ALLOWED_IPS=

# ── MCP Transport ──────────────────────────────────────────────
# Heartbeat timeout for the MCP stdio transport (0 = disabled).
# ARGUS_MCP_HEARTBEAT_TIMEOUT_SECS=60

# ── Tool Runner ─────────────────────────────────────────────────
# Extra PATH entries for tool discovery, and tool enforcement mode.
# ARGUS_EXTRA_PATH=/opt/custom-tools/bin
# ARGUS_ENFORCE_TOOLS=1           # Fail if required tools not found

# ── Worker Shutdown ─────────────────────────────────────────────
# Grace period for in-flight tasks during worker shutdown (seconds).
# WORKER_SHUTDOWN_TIMEOUT=120

# ── Findings ────────────────────────────────────────────────────
# Maximum findings stored per engagement before pruning.
# MAX_FINDINGS_PER_ENGAGEMENT=50000

# ── Vault (optional secrets backend) ────────────────────────────
# HashiCorp Vault integration for secret management.
# VAULT_ADDR=https://vault:8200
# VAULT_TOKEN=hvs.xxxxx
# VAULT_SKIP_VERIFY=false
# VAULT_TIMEOUT=10,30
# VAULT_SECRET_PATH=secret/argus

# ── AWS (optional secrets backend) ──────────────────────────────
# AWS Secrets Manager integration (alternative to Vault).
# AWS_REGION=us-east-1
# AWS_TIMEOUT=10

# ── Go Binary Path ──────────────────────────────────────────────
# Path to the Go binary (for installing Go-based security tools).
# GO_BIN_PATH=~/go/bin

# ── Advanced: Environment info ──────────────────────────────────
# Only needed when using the Settings page UI instead of .env:
# The settings page stores the key in Redis at settings:{email}:llm_api_key
# and takes priority over the env var at runtime.
