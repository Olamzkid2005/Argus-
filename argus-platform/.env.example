# Database
# L-21: Use environment variables for credentials — never hardcode passwords
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:5432/${DB_NAME}

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# L-28: Generate with: openssl rand -base64 32
# This is REQUIRED — an empty or weak secret will cause JWT forgery
NEXTAUTH_SECRET=

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AI APIs (OpenRouter - optional)
OPENROUTER_API_KEY=
