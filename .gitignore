# L-01: nuclei-templates should be a git submodule (large YAML data ~1.5M LOC)
# Convert with: git submodule add <repo_url> nuclei-templates && git rm --cached -r nuclei-templates/

# L-02: Build artifacts that may have been tracked before gitignore was added.
# Remove from tracking with: git rm --cached -r argus-platform/**/__pycache__/
